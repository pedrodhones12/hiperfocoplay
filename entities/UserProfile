{
  "name": "UserProfile",
  "type": "object",
  "properties": {
    "display_name": {
      "type": "string",
      "description": "Nome de exibi\u00e7\u00e3o do usu\u00e1rio"
    },
    "avatar_url": {
      "type": "string",
      "description": "URL da foto de perfil"
    },
    "country": {
      "type": "string",
      "enum": [
        "brasil",
        "portugal",
        "franca",
        "italia",
        "japao",
        "eua",
        "egito",
        "india",
        "china",
        "mexico"
      ],
      "description": "Pa\u00eds base para adaptar narrativas dos jogos"
    },
    "diagnosis": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "tdah",
          "autismo",
          "dislexia",
          "dificuldade_fala",
          "nenhum"
        ]
      },
      "description": "Diagn\u00f3sticos do usu\u00e1rio (privado)"
    },
    "cognitive_profile": {
      "type": "object",
      "properties": {
        "attention": {
          "type": "string",
          "enum": [
            "baixa",
            "moderada",
            "alta"
          ]
        },
        "memory": {
          "type": "string",
          "enum": [
            "baixa",
            "moderada",
            "alta"
          ]
        },
        "reading": {
          "type": "string",
          "enum": [
            "baixa",
            "moderada",
            "alta"
          ]
        },
        "visual_thinking": {
          "type": "string",
          "enum": [
            "baixa",
            "moderada",
            "alta"
          ]
        }
      }
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u00c1reas de interesse"
    },
    "total_points": {
      "type": "number",
      "default": 0,
      "description": "Pontos totais acumulados"
    },
    "level": {
      "type": "number",
      "default": 1,
      "description": "N\u00edvel atual do usu\u00e1rio"
    },
    "accessibility_settings": {
      "type": "object",
      "properties": {
        "dyslexia_font": {
          "type": "boolean",
          "default": false
        },
        "high_contrast": {
          "type": "boolean",
          "default": false
        },
        "contrast_mode": {
          "type": "string",
          "enum": [
            "normal",
            "dark",
            "light",
            "blue_yellow",
            "yellow_black"
          ],
          "default": "normal",
          "description": "Modo de contraste personalizado"
        },
        "text_to_speech": {
          "type": "boolean",
          "default": false
        },
        "audio_feedback": {
          "type": "boolean",
          "default": true,
          "description": "Feedback sonoro para a\u00e7\u00f5es"
        },
        "audio_feedback_volume": {
          "type": "number",
          "default": 0.7,
          "description": "Volume do feedback (0-1)"
        },
        "font_size": {
          "type": "string",
          "enum": [
            "pequena",
            "media",
            "grande",
            "extra_grande"
          ],
          "default": "media"
        },
        "animation_speed": {
          "type": "string",
          "enum": [
            "lenta",
            "normal",
            "rapida"
          ],
          "default": "normal"
        }
      }
    },
    "learning_preferences": {
      "type": "object",
      "properties": {
        "preferred_style": {
          "type": "string",
          "enum": [
            "visual",
            "textual",
            "interactive",
            "mixed"
          ],
          "default": "mixed",
          "description": "Estilo de aprendizagem preferido"
        },
        "content_depth": {
          "type": "string",
          "enum": [
            "resumido",
            "balanceado",
            "detalhado"
          ],
          "default": "balanceado",
          "description": "N\u00edvel de detalhamento do conte\u00fado"
        },
        "pause_frequency": {
          "type": "string",
          "enum": [
            "frequente",
            "moderado",
            "minimo"
          ],
          "default": "moderado",
          "description": "Frequ\u00eancia de pausas durante aprendizado"
        },
        "show_progress_indicators": {
          "type": "boolean",
          "default": true
        },
        "enable_gamification": {
          "type": "boolean",
          "default": true
        },
        "prefer_step_by_step": {
          "type": "boolean",
          "default": false,
          "description": "Prefer\u00eancia por instru\u00e7\u00f5es passo a passo"
        }
      }
    }
  },
  "required": [
    "display_name",
    "country"
  ]
}
